---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Kontakt">
  <Header />
  <main class="min-h-screen pt-32 pb-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16 gsap-fade-up">
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">Kostenlose Beratung</h1>
        <p class="text-xl text-gray-600 dark:text-gray-400">
          Füllen Sie einfach das Formular aus und wir werden uns umgehend mit Ihnen in Verbindung setzen. Gemeinsam besprechen wir, wie oneDialog Ihre Marke unterstützen kann.
        </p>
      </div>

      <div class="bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-12 shadow-xl border border-gray-100 dark:border-zinc-800 gsap-fade-up">
        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">Vorname *</label>
              <input type="text" class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-zinc-700 bg-gray-50 dark:bg-zinc-950 focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
            </div>
            <div>
              <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">Nachname *</label>
              <input type="text" class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-zinc-700 bg-gray-50 dark:bg-zinc-950 focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">E-Mail *</label>
            <input type="email" class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-zinc-700 bg-gray-50 dark:bg-zinc-950 focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
          </div>

          <div>
            <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">Unternehmen *</label>
            <input type="text" class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-zinc-700 bg-gray-50 dark:bg-zinc-950 focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
          </div>

          <div>
            <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">Nachricht</label>
            <textarea rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-zinc-700 bg-gray-50 dark:bg-zinc-950 focus:ring-2 focus:ring-blue-500 outline-none transition-all"></textarea>
          </div>

          <div class="flex items-start gap-3">
            <input type="checkbox" id="privacy" class="mt-1.5" required />
            <label for="privacy" class="text-sm text-gray-600 dark:text-gray-400">
              Ich bin damit einverstanden, dass meine Kontaktdaten zur Kontaktaufnahme verwendet werden. Meine Daten werden vertraulich behandelt. Weitere Informationen in der <a href="/rechtliches/datenschutzerklarung" class="text-blue-600 dark:text-blue-400 underline">Datenschutzrichtlinie</a>.
            </label>
          </div>

          <button type="button" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl transition-colors">
            Beratung anfordern
          </button>
        </form>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const fadeUps = document.querySelectorAll('.gsap-fade-up');
  fadeUps.forEach((element) => {
    gsap.fromTo(element,
      { y: 30, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: element,
          start: "top 85%",
        }
      }
    );
  });
</script>
