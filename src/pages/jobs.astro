---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Jobs">
  <Header />
  <main class="min-h-screen pt-32 pb-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="gsap-fade-up">
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">Jobs</h1>
        <p class="text-xl text-gray-600 dark:text-gray-400 mb-12">
          Wir suchen Verstärkung für unser Team. Gestalte mit uns die Zukunft der Kundenkommunikation.
        </p>
      </div>

      <div class="bg-gray-50 dark:bg-zinc-900 rounded-3xl p-12 gsap-fade-up">
         <h2 class="text-2xl font-bold mb-4">Aktuell keine offenen Stellen</h2>
         <p class="text-gray-600 dark:text-gray-400">
           Derzeit haben wir keine Vakanzen. Schau gerne bald wieder vorbei oder sende uns eine Initiativbewerbung an <a href="mailto:info@onedialog.io" class="text-blue-600 dark:text-blue-400">info@onedialog.io</a>.
         </p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const fadeUps = document.querySelectorAll('.gsap-fade-up');
  fadeUps.forEach((element) => {
    gsap.fromTo(element,
      { y: 30, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: element,
          start: "top 85%",
        }
      }
    );
  });
</script>
