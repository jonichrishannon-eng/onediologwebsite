---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Die App">
  <Header />
  <main class="min-h-screen pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-20 gsap-fade-up">
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">oneDialog App</h1>
        <p class="text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
          Das Werkzeug für Ihre Vertriebspartner. Alles in der Tasche, jederzeit bereit.
        </p>
      </div>

      <div class="space-y-32">
        <section id="dashboard" class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center gsap-fade-up">
          <div>
            <h2 class="text-3xl font-bold mb-6">Dashboard</h2>
            <p class="text-gray-600 dark:text-gray-400 text-lg mb-6 leading-relaxed">Der perfekte Überblick über alle laufenden Aktivitäten, neue Leads und anstehende Aufgaben.</p>
          </div>
          <div class="bg-gray-100 dark:bg-zinc-900 rounded-3xl p-8 flex items-center justify-center">
             <img src="/assets/616fff29990abe9e50b1dc6f_app_dashboard.png" class="max-h-96 object-contain drop-shadow-2xl rounded-2xl" alt="Dashboard" />
          </div>
        </section>

        <section id="inbox" class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center flex-col-reverse md:flex-row-reverse gsap-fade-up">
          <div>
            <h2 class="text-3xl font-bold mb-6">Zentrale Inbox</h2>
            <p class="text-gray-600 dark:text-gray-400 text-lg mb-6 leading-relaxed">Alle Kanäle an einem Ort. WhatsApp, E-Mail und Social Media nahtlos in einem Postfach gebündelt.</p>
          </div>
          <div class="bg-gray-100 dark:bg-zinc-900 rounded-3xl p-8 flex items-center justify-center">
             <div class="w-full max-w-sm aspect-[9/16] bg-white dark:bg-zinc-800 rounded-3xl shadow-xl flex items-center justify-center text-gray-400">Mockup Inbox</div>
          </div>
        </section>

        <!-- Other features quickly summarized -->
        <section class="grid grid-cols-1 md:grid-cols-3 gap-8 gsap-fade-up">
           <div id="aufgaben" class="bg-gray-50 dark:bg-zinc-900 p-8 rounded-3xl">
              <h3 class="text-xl font-bold mb-4">Aufgabenmanagement</h3>
              <p class="text-gray-600 dark:text-gray-400">Strukturieren Sie den Arbeitsalltag effizient und verpassen Sie keine Follow-ups.</p>
           </div>
           <div id="kundenprofile" class="bg-gray-50 dark:bg-zinc-900 p-8 rounded-3xl">
              <h3 class="text-xl font-bold mb-4">Kundenprofile</h3>
              <p class="text-gray-600 dark:text-gray-400">360-Grad Blick auf Ihre Kunden. Alle Informationen und Historien auf einen Klick.</p>
           </div>
           <div id="teamarbeit" class="bg-gray-50 dark:bg-zinc-900 p-8 rounded-3xl">
              <h3 class="text-xl font-bold mb-4">Teamarbeit</h3>
              <p class="text-gray-600 dark:text-gray-400">Arbeiten Sie nahtlos im Team zusammen, delegieren Sie Aufgaben und kommunizieren Sie intern.</p>
           </div>
        </section>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const fadeUps = document.querySelectorAll('.gsap-fade-up');
  fadeUps.forEach((element) => {
    gsap.fromTo(element,
      { y: 30, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: element,
          start: "top 85%",
        }
      }
    );
  });
</script>
